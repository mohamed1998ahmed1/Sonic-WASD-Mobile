<Window x:Class="SonicWASD.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sonic Settings" Height="700" Width="500" Background="Transparent" 
        WindowStyle="None" AllowsTransparency="True" WindowStartupLocation="CenterOwner">

    <Border BorderBrush="#00D4FF" BorderThickness="2" CornerRadius="20" Background="#0A0A0A" Margin="10">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="إعدادات SONIC المتقدمة" Foreground="#00D4FF" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="⚙️ إعدادات عامة" Foreground="#00D4FF" FontSize="16" Margin="0,10"/>
                    <Border Background="#111" CornerRadius="10" Padding="15" Margin="0,0,0,20">
                        <StackPanel>
                            <DockPanel Margin="0,5">
                                <TextBlock Text="اللغة (Languages):" Foreground="White" VerticalAlignment="Center"/>
                                <ComboBox HorizontalAlignment="Right" Width="120" Background="#222" Foreground="Black">
                                    <ComboBoxItem Content="العربية" IsSelected="True"/>
                                    <ComboBoxItem Content="English"/>
                                </ComboBox>
                            </DockPanel>

                            <DockPanel Margin="0,10">
                                <TextBlock Text="مفتاح الاختصار (Boss Key):" Foreground="White" VerticalAlignment="Center"/>
                                <TextBox Text="Ctrl+Alt+Q" HorizontalAlignment="Right" Width="120" Background="#222" Foreground="White" BorderBrush="#333"/>
                            </DockPanel>

                            <DockPanel Margin="0,10">
                                <TextBlock Text="اتجاه الشاشة:" Foreground="White" VerticalAlignment="Center"/>
                                <ComboBox HorizontalAlignment="Right" Width="120" Background="#222">
                                    <ComboBoxItem Content="طبيعي" IsSelected="True"/>
                                    <ComboBoxItem Content="تدوير 90°"/>
                                </ComboBox>
                            </DockPanel>

                            <Separator Background="#333" Margin="0,10"/>

                            <CheckBox Content="إظهار وضع المفاتيح" Foreground="White" Margin="0,5" FlowDirection="RightToLeft"/>
                            <CheckBox Content="عرض معدل الفريمات FPS" Foreground="White" IsChecked="True" Margin="0,5" FlowDirection="RightToLeft"/>

                            <TextBlock Text="الشفافية (Transparency):" Foreground="White" Margin="0,10,0,5"/>
                            <Slider Minimum="20" Maximum="100" Value="85" TickFrequency="1" Foreground="#00D4FF"/>

                            <TextBlock Text="حساسية الماوس العالمية:" Foreground="White" Margin="0,10,0,5"/>
                            <Slider Minimum="1" Maximum="20" Value="8" Foreground="#00D4FF"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="🚀 إعدادات الأداء (Sonic Speed)" Foreground="#00D4FF" FontSize="16" Margin="0,10"/>
                    <Border Background="#111" CornerRadius="10" Padding="15">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,15">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="تمكين نقل الصوت" Foreground="White" VerticalAlignment="Center"/>
                                    <TextBlock Text="(VIP)" Foreground="#FFD700" FontSize="10" Margin="5,0" VerticalAlignment="Top" FontWeight="Bold"/>
                                </StackPanel>
                                <CheckBox x:Name="AudioToggle" IsChecked="True" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <CheckBox.LayoutTransform>
                                        <ScaleTransform ScaleX="1.3" ScaleY="1.3"/>
                                    </CheckBox.LayoutTransform>
                                </CheckBox>
                            </DockPanel>
                            <TextBlock Text="أندرويد 11 أو أعلى مطلوب لنقل الصوت" Foreground="Gray" FontSize="10" Margin="0,-10,0,10" HorizontalAlignment="Right"/>

                            <Separator Background="#333" Margin="0,5"/>

                            <TextBlock Text="معدل البت (Bitrate): 16 Mbps" Foreground="White" Margin="0,10,0,5"/>
                            <Slider Minimum="1" Maximum="50" Value="16" Foreground="#00D4FF"/>

                            <TextBlock Text="دقة الفيديو (Resolution): 720P" Foreground="White" Margin="0,15,0,5"/>
                            <Slider Minimum="480" Maximum="1080" Value="720" Foreground="#00D4FF"/>

                            <DockPanel Margin="0,15">
                                <TextBlock Text="أقصى معدل FPS:" Foreground="White" VerticalAlignment="Center"/>
                                <ComboBox HorizontalAlignment="Right" Width="100">
                                    <ComboBoxItem Content="30 FPS"/>
                                    <ComboBoxItem Content="60 FPS" IsSelected="True"/>
                                    <ComboBoxItem Content="90 FPS"/>
                                    <ComboBoxItem Content="120 FPS"/>
                                </ComboBox>
                            </DockPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                <Button Content="حفظ الإعدادات" Width="150" Height="40" Background="#00D4FF" Foreground="Black" FontWeight="Bold" Margin="10,0" Click="Save_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </Button.Resources>
                </Button>
                <Button Content="إلغاء" Width="100" Height="40" Background="#333" Foreground="White" Click="CloseSettings_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
