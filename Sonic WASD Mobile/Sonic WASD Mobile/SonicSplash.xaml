<Window x:Class="Sonic_WASD_Mobile.SonicSplash"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sonic WASD - Loading" 
        Height="400" Width="550" 
        Background="Transparent" 
        WindowStyle="None" 
        AllowsTransparency="True"
        WindowStartupLocation="CenterScreen"
        Opacity="1">

    <Window.Resources>
        <Storyboard x:Key="SonicPulseAnim" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="SplashGlow" 
                             Storyboard.TargetProperty="Opacity" 
                             From="0.4" To="1.0" 
                             Duration="0:0:1.5" />
        </Storyboard>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard Storyboard="{StaticResource SonicPulseAnim}"/>
        </EventTrigger>
    </Window.Triggers>

    <Border BorderBrush="#00D4FF" BorderThickness="2" Margin="10" CornerRadius="20" Background="#0A0A0A">
        <Border.Effect>
            <DropShadowEffect Color="#00D4FF" BlurRadius="15" ShadowDepth="0" Opacity="0.5"/>
        </Border.Effect>

        <Grid>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="SONIC WASD" FontSize="40" FontWeight="Bold" Foreground="#00D4FF" HorizontalAlignment="Center">
                    <TextBlock.Effect>
                        <DropShadowEffect x:Name="SplashGlow" Color="#00D4FF" BlurRadius="10" ShadowDepth="0" Opacity="0.8"/>
                    </TextBlock.Effect>
                </TextBlock>

                <TextBlock Text="جاري تهيئة محرك الاتصال..." Foreground="#888" FontSize="14" HorizontalAlignment="Center" Margin="0,20,0,0"/>

                <ProgressBar IsIndeterminate="True" Width="250" Height="4" Margin="0,35,0,0" 
                             Foreground="#00D4FF" Background="#1A1A1A" BorderThickness="0">
                    <ProgressBar.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="2"/>
                        </Style>
                    </ProgressBar.Resources>
                </ProgressBar>

                <TextBlock Text="V 1.0.0" Foreground="#333" FontSize="11" HorizontalAlignment="Center" Margin="0,10,0,0"/>
            </StackPanel>

            <TextBlock Text="POWERED BY SONIC ENGINE" Foreground="#111" FontSize="10" 
                       HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,15"/>
        </Grid>
    </Border>
</Window>