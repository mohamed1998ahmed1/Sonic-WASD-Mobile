<Window x:Class="Sonic_WASD_Mobile.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sonic WASD+" Height="620" Width="450" 
        Background="Transparent" WindowStyle="None" AllowsTransparency="True"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        MouseDown="Window_MouseDown">

    <Window.Resources>
        <Storyboard x:Key="SonicPulseAnim" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="SonicGlow" 
                             Storyboard.TargetProperty="Opacity" 
                             From="0.3" To="1.0" 
                             Duration="0:0:1.5" />
            <DoubleAnimation Storyboard.TargetName="SonicGlow" 
                             Storyboard.TargetProperty="BlurRadius" 
                             From="5" To="25" 
                             Duration="0:0:1.5" />
        </Storyboard>

        <Storyboard x:Key="BlinkStatusAnimation" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="StatusLabel" Storyboard.TargetProperty="Opacity" From="1" To="0.3" Duration="0:0:1" AutoReverse="True"/>
        </Storyboard>

        <Style x:Key="SonicButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Black"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#151515"/>
                    <Setter Property="Foreground" Value="#00D4FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard Storyboard="{StaticResource SonicPulseAnim}"/>
            <BeginStoryboard Storyboard="{StaticResource BlinkStatusAnimation}"/>
        </EventTrigger>
    </Window.Triggers>

    <Border BorderBrush="#00D4FF" BorderThickness="2" Margin="15" CornerRadius="25" Background="#050505">
        <Border.Effect>
            <DropShadowEffect Color="#00D4FF" BlurRadius="20" ShadowDepth="0" Opacity="0.4"/>
        </Border.Effect>

        <Grid>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,15,20,0">
                <Button Content="_" Foreground="White" Background="Transparent" BorderThickness="0" FontSize="18" Width="30" Click="Minimize_Click" Cursor="Hand"/>
                <Button Content="✕" Foreground="#FF4B4B" Background="Transparent" BorderThickness="0" FontSize="16" Width="30" Click="Close_Click" Cursor="Hand"/>
            </StackPanel>

            <TextBlock x:Name="SonicText" Text="SONIC WASD" FontSize="34" FontWeight="ExtraBold" HorizontalAlignment="Center" Margin="0,35,0,0">
                <TextBlock.Foreground>
                    <SolidColorBrush Color="#00D4FF"/>
                </TextBlock.Foreground>
                <TextBlock.Effect>
                    <DropShadowEffect x:Name="SonicGlow" Color="#00D4FF" BlurRadius="15" ShadowDepth="0" Opacity="0.8"/>
                </TextBlock.Effect>
            </TextBlock>

            <ListBox x:Name="DeviceList" Margin="25,100,25,240" Background="#000" Foreground="White" BorderBrush="#1A1A1A" FontSize="14" BorderThickness="1.5">
                <ListBox.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="10"/>
                    </Style>
                </ListBox.Resources>
            </ListBox>

            <StackPanel VerticalAlignment="Bottom" Margin="0,0,0,185" Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock x:Name="BatteryStatus" Text="🔋 البطارية: --%" Foreground="#00FF00" FontSize="15" FontWeight="SemiBold" Margin="0,0,20,0"/>
                <TextBlock x:Name="TempStatus" Text="🌡️ الحرارة: --°C" Foreground="#FF4500" FontSize="15" FontWeight="SemiBold"/>
            </StackPanel>

            <StackPanel VerticalAlignment="Bottom" Margin="25,0,25,65">
                <Button Content="📱 الاتصال المباشر بالجهاز" Click="Connect_Click" Height="50" 
                        Background="#00D4FF" Foreground="Black" FontWeight="Bold" Margin="0,5"
                        Style="{StaticResource SonicButtonStyle}" BorderThickness="0"/>

                <Button Content="تحديث القائمة" Click="Refresh_Click" Height="45" Margin="0,5" 
                        BorderBrush="#00D4FF" BorderThickness="2" 
                        Style="{StaticResource SonicButtonStyle}">
                    <Button.Effect>
                        <DropShadowEffect Color="#00D4FF" BlurRadius="10" ShadowDepth="0" Opacity="0.3"/>
                    </Button.Effect>
                </Button>
            </StackPanel>

            <Grid VerticalAlignment="Bottom" Margin="25,0,25,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusLabel" Grid.Column="0" Text="متصل ⚡" Foreground="#00D4FF" FontSize="11" VerticalAlignment="Center" FontWeight="Bold" HorizontalAlignment="Left"/>
                <Button Grid.Column="1" Click="ExitApp_Click" Height="35" Background="#100000" BorderBrush="#FF4B4B" BorderThickness="1.5" HorizontalAlignment="Center" Width="100">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                    <TextBlock Text="🔴 خروج" Foreground="#FF4B4B" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                </Button>
                <Button Grid.Column="2" Click="Settings_Click" Background="Transparent" BorderThickness="0" HorizontalAlignment="Right">
                    <TextBlock Text="⚙ Settings" Foreground="#00D4FF" FontSize="13" Opacity="0.6"/>
                </Button>
            </Grid>
        </Grid>
    </Border>
</Window>